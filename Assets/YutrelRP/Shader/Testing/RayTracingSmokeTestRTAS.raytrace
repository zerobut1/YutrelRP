#pragma max_recursion_depth 1

RWTexture2D<float4> _RayTracingSmokeTestOutput;
RaytracingAccelerationStructure _RaytracingAccelerationStructure;

float4x4 _RayTracingSmokeTestInvViewProjection;
float3 _RayTracingSmokeTestCameraPositionWS;

struct SmokeTestPayload
{
    uint hit;
    float rayT;
};

[shader("miss")]
void Miss(inout SmokeTestPayload payload : SV_RayPayload)
{
    payload.hit = 0;
    payload.rayT = -1.0;
}

[shader("closesthit")]
void ClosestHit(inout SmokeTestPayload payload : SV_RayPayload, BuiltInTriangleIntersectionAttributes attributes)
{
    payload.hit = 1;
    payload.rayT = RayTCurrent();
}

float3 BuildCameraRayDirection(uint2 pixel, uint2 dimensions)
{
    float2 uv = (float2(pixel) + 0.5) / max(float2(dimensions), 1.0);
    float2 clipXY = uv * 2.0 - 1.0;
    clipXY.y = -clipXY.y;

    float4 farPositionCS = float4(clipXY, 1.0, 1.0);
    float4 farPositionWS = mul(_RayTracingSmokeTestInvViewProjection, farPositionCS);
    farPositionWS.xyz /= max(farPositionWS.w, 1.0e-6);

    return normalize(farPositionWS.xyz - _RayTracingSmokeTestCameraPositionWS);
}

[shader("raygeneration")]
void RayGenSmokeTestRTAS()
{
    uint3 launchIndex = DispatchRaysIndex();
    uint3 launchDimensions = DispatchRaysDimensions();
    uint2 pixel = launchIndex.xy;
    uint2 dimensions = launchDimensions.xy;

    RayDesc ray;
    ray.Origin = _RayTracingSmokeTestCameraPositionWS;
    ray.Direction = BuildCameraRayDirection(pixel, dimensions);
    ray.TMin = 0.001;
    ray.TMax = 100000.0;

    SmokeTestPayload payload;
    payload.hit = 0;
    payload.rayT = -1.0;

    TraceRay(_RaytracingAccelerationStructure,
             RAY_FLAG_CULL_BACK_FACING_TRIANGLES,
             0xFF,
             0,
             1,
             0,
             ray,
             payload);

    if (payload.hit != 0)
    {
        float depthCue = saturate(1.0 - payload.rayT / 100.0);
        _RayTracingSmokeTestOutput[pixel] = float4(1.0, depthCue, 0.05, 1.0);
    }
    else
    {
        _RayTracingSmokeTestOutput[pixel] = float4(0.02, 0.08, 0.35, 1.0);
    }
}
